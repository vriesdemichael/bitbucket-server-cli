{
  "$id": "https://vriesdemichael.github.io/bitbucket-server-cli/latest/reference/schemas/output/output.auth.token-url.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "JSON output schema for `bb auth token-url --json`. Data contains the personal access token creation URL.",
  "properties": {
    "data": {
      "additionalProperties": false,
      "properties": {
        "bitbucket_url": {
          "description": "Bitbucket Server base URL.",
          "type": "string"
        },
        "token_url": {
          "description": "URL to the personal access token creation page.",
          "format": "uri",
          "type": "string"
        }
      },
      "required": [
        "bitbucket_url",
        "token_url"
      ],
      "type": "object"
    },
    "meta": {
      "additionalProperties": false,
      "properties": {
        "contract": {
          "const": "bb.machine"
        }
      },
      "required": [
        "contract"
      ],
      "type": "object"
    },
    "version": {
      "const": "v2"
    }
  },
  "required": [
    "version",
    "data",
    "meta"
  ],
  "title": "bb auth token-url output",
  "type": "object"
}
